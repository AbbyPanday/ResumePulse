rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'abbypanday7@gmail.com'; }
    function isAllowed(userId) { return isOwner(userId) || isAdmin(); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidUser(data) {
      return data.uid is string && data.email is string && data.email.matches('^[^@]+@[^@]+\\.[^@]+$');
    }

    function isValidAnalysis(data) {
      return data.userId is string && data.score is number;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow get, list: if isAllowed(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;
      
      match /analyses/{analysisId} {
        allow get, list: if isAllowed(userId);
        allow create: if isOwner(userId) && isValidAnalysis(request.resource.data);
        allow update: if isOwner(userId) && isValidAnalysis(request.resource.data) && request.resource.data.userId == resource.data.userId;
      }
    }
  }
}
